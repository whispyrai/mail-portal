# Local dev secrets. Copy to the environment-specific file you are running:
#   cp .dev.vars.example .dev.vars.whispyr
#   cp .dev.vars.example .dev.vars.wiser
# Both are gitignored. Do not use one generic .dev.vars for both brands: Wrangler
# otherwise makes those credentials available to every named local environment.

# AWS SES outbound (eu-west-2). Use that brand's dedicated send-only IAM user.
# Region is set in wrangler.jsonc (AWS_REGION); these two are secrets.
AWS_ACCESS_KEY_ID=your-ses-iam-access-key-id
AWS_SECRET_ACCESS_KEY=your-ses-iam-secret-access-key

# Shared secret authenticating AWS SES delivery-event webhooks.
SES_EVENT_WEBHOOK_SECRET=your-long-random-ses-webhook-secret
# Stable AES-GCM/HMAC root for version-1 recovery ciphertext and opaque refs.
# Keep it separate from JWT_SECRET and do not rotate it in place.
CREDENTIAL_RECOVERY_PAYLOAD_KEY_V1=your-stable-credential-recovery-payload-key

# Session signing secret (64+ random bytes). Generate with:
#   openssl rand -base64 48
JWT_SECRET=your-long-random-jwt-secret

# Verified external destination used only if both raw R2 archival and direct
# Mailbox persistence fail. Configure the approved address per environment.

# Email allowed to self-provision the first ADMIN account on first login.
ADMIN_BOOTSTRAP_EMAIL=replace-with-the-brand-admin-address

# Operator-managed JSON map from portal addresses to approved external recovery
# addresses. Keep this separate per brand.
ACCOUNT_RECOVERY_DIRECTORY={"member@example.com":"member@recovery.example"}

# Web Push VAPID keypair (WISER-240). Generate once with:
#   npx web-push generate-vapid-keys
# VAPID_SUBJECT is a plain var in wrangler.jsonc; the keypair is secret.
# In prod: wrangler secret put VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY --env <brand>.
# Leave blank to run without push (mail still receives).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
